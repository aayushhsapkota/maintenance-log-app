<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Fix_It.Views.ReportIssuePage"
             Title="Report Issue"
             BackgroundColor="{StaticResource PageBackground}">

    <!-- Element-level override: BackgroundColor is set directly on this ContentPage instance,
         overriding the Generic "Page" style (white) in Styles.xaml, since only this page
         uses the mockup's light-gray body background. -->

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="New maintenance request"
                   TextColor="{StaticResource Gray500}"
                   Margin="0,0,0,8" />

            <!-- Card containing the form, matching the white rounded panel in Report Issue.png. -->
            <Border BackgroundColor="{StaticResource CardBackground}"
                    Stroke="{StaticResource BorderGray}"
                    StrokeShape="RoundRectangle 14"
                    StrokeThickness="1"
                    Padding="20">
                <VerticalStackLayout Spacing="14">

                    <Label Text="Issue Details"
                           FontFamily="OpenSansSemibold"
                           FontSize="18" />
                    <BoxView HeightRequest="1" Color="{StaticResource BorderGray}" />

                    <Label Text="Issue Title *" Style="{StaticResource FieldLabel}" />
                    <Border Style="{StaticResource FieldBorder}">
                        <Entry Text="{Binding Title}"
                               Placeholder="e.g. Broken AC — Floor 3"
                               VerticalOptions="Center" />
                    </Border>

                    <Label Text="Location / Room *" Style="{StaticResource FieldLabel}" />
                    <Border Style="{StaticResource FieldBorder}">
                        <Entry Text="{Binding Location}"
                               Placeholder="e.g. Floor 3, Room 302"
                               VerticalOptions="Center" />
                    </Border>

                    <Label Text="Description *" Style="{StaticResource FieldLabel}" />
                    <Border Stroke="{StaticResource BorderGray}"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="1"
                            Padding="14,8"
                            HeightRequest="110">
                        <Editor Text="{Binding Description}"
                                Placeholder="Describe the issue in detail..." />
                    </Border>

                    <Label Text="Priority Level *" Style="{StaticResource FieldLabel}" />
                    <Border Style="{StaticResource FieldBorder}">
                        <Picker ItemsSource="{Binding Priorities}"
                                SelectedItem="{Binding SelectedPriority}"
                                Title="Select priority"
                                VerticalOptions="Center" />
                    </Border>

                    <Label Text="{Binding ErrorMessage}"
                           Style="{StaticResource ErrorLabel}"
                           IsVisible="{Binding HasError}" />

                    <Button Text="Submit Report"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding SubmitCommand}"
                            Margin="0,10,0,0" />

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
